# Absolute path to the Obsidian vault used for local plugin testing.
OBSIDIAN_VAULT_PATH="/absolute/path/to/your/vault"

# Optional Obsidian CLI vault name. Leave empty to run the CLI from OBSIDIAN_VAULT_PATH.
OBSIDIAN_CLI_VAULT=""

# Optional. Defaults to manifest.json id.
OBSIDIAN_PLUGIN_ID="obsius"

# Optional delay after app:reload before verify.
OBSIDIAN_RELOAD_WAIT_MS="2000"
